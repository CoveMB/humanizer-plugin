{
  "cases": [
    {
      "id": "dense_ai_rewrite",
      "mode": "rewrite",
      "tags": [
        "rewrite_only_output",
        "factual_integrity",
        "no_em_dash",
        "no_chatbot_wrapper",
        "no_contrast_frame",
        "no_rule_of_three",
        "no_self_narration",
        "preserve_supplied_facts"
      ],
      "prompt": "Humanize this text. Return only the rewritten text.",
      "source": "Great question! Here is an overview. AI coding assistants serve as an enduring testament to the transformative potential of large language models, marking a pivotal moment in the rapidly evolving landscape of software development. At its core, the value proposition is clear: streamlining documentation, enhancing tests, and fostering alignment. It is not just about autocomplete; it is about unlocking creativity at scale. Industry observers have noted adoption is rising. Let me know if you want more detail.",
      "constraints": {
        "must_include": [
          "AI coding assistants",
          "doc",
          "test"
        ],
        "must_not_include": [
          "Great question",
          "Here is",
          "enduring testament",
          "transformative potential",
          "pivotal moment",
          "rapidly evolving landscape",
          "At its core",
          "streamlining",
          "enhancing",
          "fostering",
          "not just",
          "unlocking creativity",
          "Industry observers",
          "Let me know"
        ],
        "must_not_match": [
          "(?i)future looks bright",
          "(?i)game[- ]changer"
        ],
        "no_em_dash": true,
        "no_chatbot_wrapper": true,
        "no_contrast_frame": true,
        "no_markdown_fence": true,
        "rewrite_only": true
      }
    },
    {
      "id": "missing_source_handling",
      "mode": "rewrite",
      "tags": [
        "rewrite_only_output",
        "factual_integrity",
        "missing_source_handling",
        "preserve_supplied_facts"
      ],
      "prompt": "Humanize this. If a sentence needs missing facts to become specific, ask instead of inventing.",
      "source": "Industry reports show that Atlas Note adoption increased by 43% last quarter, underscoring its crucial role in the productivity ecosystem.",
      "constraints": {
        "must_include": [
          "Atlas Note",
          "43%",
          "last quarter"
        ],
        "must_not_include": [
          "Gartner",
          "Forrester",
          "McKinsey",
          "IDC",
          "Deloitte",
          "according to a",
          "survey of",
          "study found",
          "crucial role",
          "productivity ecosystem"
        ],
        "no_em_dash": true,
        "no_chatbot_wrapper": true,
        "no_contrast_frame": true,
        "no_markdown_fence": true,
        "rewrite_only": true
      }
    },
    {
      "id": "voice_calibration",
      "mode": "rewrite",
      "tags": [
        "rewrite_only_output",
        "voice_calibration",
        "preserve_supplied_facts",
        "no_em_dash"
      ],
      "prompt": "Humanize this text. Match this writing sample: I keep my notes short because I actually read them later. If a tool makes me babysit it, I stop using it. Draft:",
      "source": "The ChronoPad release introduces a significantly enhanced offline mode, showcasing the team's commitment to seamless productivity. Users can now edit notes on flights and sync them when they reconnect.",
      "constraints": {
        "must_include": [
          "ChronoPad",
          "offline",
          "flight",
          "sync"
        ],
        "must_not_include": [
          "significantly enhanced",
          "showcasing",
          "commitment",
          "seamless productivity"
        ],
        "no_em_dash": true,
        "no_chatbot_wrapper": true,
        "no_contrast_frame": true,
        "no_markdown_fence": true,
        "rewrite_only": true
      }
    },
    {
      "id": "audit_mode",
      "mode": "audit",
      "tags": [
        "audit_output",
        "factual_integrity",
        "no_fake_naming",
        "no_self_narration"
      ],
      "prompt": "Audit and score this draft for AI-writing patterns. Put the rewrite first, then brief notes.",
      "source": "The Momentum Flywheel is a groundbreaking framework that highlights how teams can unlock collaboration. The key takeaway is that alignment matters.",
      "constraints": {
        "rewrite_must_not_include": [
          "Momentum Flywheel",
          "groundbreaking framework",
          "highlights",
          "unlock collaboration",
          "The key takeaway"
        ],
        "must_not_match": [
          "(?i)^here is",
          "(?i)i hope this helps"
        ],
        "must_match": [
          "(?i)\\bteams\\b",
          "(?i)(align\\w*|agree\\w*|shared direction)",
          "(?i)score\\s*:?\\s*\\d{1,2}/80"
        ],
        "no_em_dash": true,
        "no_chatbot_wrapper": true,
        "no_contrast_frame": true,
        "no_markdown_fence": true,
        "max_question_marks": 0
      }
    },
