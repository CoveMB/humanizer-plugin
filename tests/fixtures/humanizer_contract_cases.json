    {
      "id": "negative_fact_check_only",
      "mode": "answer",
      "tags": [
        "negative_no_trigger"
      ],
      "prompt": "Fact-check this claim and list what evidence would be needed. Do not rewrite it.",
      "source": "Atlas Note adoption increased by 43% last quarter according to industry reports.",
      "constraints": {
        "must_include": [
          "Atlas Note",
          "43%",
          "evidence"
        ],
        "must_not_include": [
          "Humanizer",
          "rewritten text",
          "cleaner rewrite"
        ],
        "no_chatbot_wrapper": true,
        "no_markdown_fence": true
      }
    },
    {
      "id": "negative_translate_only",
      "mode": "translate",
      "tags": [
        "negative_no_trigger"
      ],
      "prompt": "Translate this sentence into French. Do not edit the style.",
      "source": "The product includes offline comments and faster issue search.",
      "constraints": {
        "must_match": [
          "(?i)\\bproduit\\b",
          "(?i)hors[- ]ligne",
          "(?i)recherche"
        ],
        "must_not_include": [
          "offline comments",
          "faster issue search",
          "Humanizer"
        ],
        "no_chatbot_wrapper": true,
        "no_markdown_fence": true
      }
    },
    {
      "id": "negative_summary_only",
      "mode": "summary",
      "tags": [
        "negative_no_trigger"
      ],
      "prompt": "Summarize this into one bullet without rewriting the prose style.",
      "source": "The release includes offline comments, faster issue search, and a redesigned notification settings page.",
      "constraints": {
        "must_include": [
          "offline comments",
          "faster issue search",
          "redesigned notification settings page"
        ],
        "must_match": [
          "(?m)^\\s*[-*]\\s+"
